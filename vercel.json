{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "routes": [
    {
      "src": "^/(.*)$",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=()"
      },
      "continue": true
    },
    { "src": "^/$", "dest": "/api/render-page-postprocess?file=index.html" },
    { "src": "^/entites-publiques$", "dest": "/api/render-page-postprocess?file=entites-publiques.html" },
    { "src": "^/entreprises-privees$", "dest": "/api/render-page-enterprises?file=entreprises-privees.html" },
    { "src": "^/services$", "dest": "/api/render-page-postprocess?file=services.html" },
    { "src": "^/faq$", "dest": "/api/render-page-postprocess?file=faq.html" },
    { "src": "^/mentions-legales$", "dest": "/api/render-page-postprocess?file=mentions-legales.html" },
    { "src": "^/outils-gratuits$", "dest": "/api/render-page-postprocess?file=outils-gratuits.html" },
    { "src": "^/grille-mapa$", "dest": "/api/render-page-postprocess?file=grille-mapa.html" },
    { "src": "^/insights$", "dest": "/insights.html" },
    { "src": "^/insights/([a-z0-9-]+)$", "dest": "/api/render-insight?slug=$1" },
    { "src": "^/articles.json$", "dest": "/articles.json" },
    { "src": "^/articles/(.*)$", "dest": "/articles/$1" },
    { "src": "^/sitemap.xml$", "dest": "/sitemap.xml" },
    { "src": "^/site-data.json$", "dest": "/site-data.json" },
    { "src": "^/admin$", "dest": "/admin.html" },
    { "src": "^/img/(.*)$", "dest": "/img/$1" },
    { "src": "^/robots.txt$", "dest": "/robots.txt" },
    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}
