{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/render-page?file=index.html"
    },
    {
      "source": "/entites-publiques",
      "destination": "/api/render-page?file=entites-publiques.html"
    },
    {
      "source": "/entreprises-privees",
      "destination": "/api/render-page?file=entreprises-privees.html"
    },
    {
      "source": "/services",
      "destination": "/api/render-page?file=services.html"
    },
    {
      "source": "/faq",
      "destination": "/api/render-page?file=faq.html"
    },
    {
      "source": "/mentions-legales",
      "destination": "/api/render-page?file=mentions-legales.html"
    },
    {
      "source": "/outils-gratuits",
      "destination": "/api/render-page?file=outils-gratuits.html"
    },
    {
      "source": "/grille-mapa",
      "destination": "/api/render-page?file=grille-mapa.html"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/site-data.json",
      "destination": "/site-data.json"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/img/:file",
      "destination": "/img/:file"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/site-data.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
